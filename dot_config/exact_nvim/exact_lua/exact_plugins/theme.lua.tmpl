-- Theme plugin spec. Generated by chezmoi from the active preset; only the
-- selected colorscheme plugin is installed. Dark/light follows macOS appearance
-- at startup and on FocusGained.
{{- $p := index .presets .theme.preset }}

local function is_dark()
  local h = io.popen("defaults read -g AppleInterfaceStyle 2>/dev/null")
  local out = h and h:read("*a") or ""
  if h then h:close() end
  return out:lower():find("dark") ~= nil
end

local function setup_devicons()
  local function ruby_icon(name)
    return { icon = "", color = "#701516", cterm_color = "52", name = name }
  end
  require("nvim-web-devicons").setup({
    override = {
      ["jbuilder.tt"] = ruby_icon("jbuilder"),
      ["rb.tt"] = ruby_icon("ruby"),
      jbuilder = ruby_icon("jbuilder"),
      Gemfile = ruby_icon("Gemfile"),
      Dangerfile = ruby_icon("Dangerfile"),
      Brewfile = ruby_icon("Brewfile"),
    }
  })
end

return {
  "{{ $p.nvim.plugin }}",
{{- if eq .theme.preset "catppuccin" }}
  name = "catppuccin",
{{- end }}
  lazy = false,
  priority = 1000,
  config = function()
    setup_devicons()

    local function apply()
      vim.o.background = is_dark() and "dark" or "light"
{{- if eq .theme.preset "onedark" }}
      require("onedark").setup({ style = vim.o.background == "dark" and "warmer" or "light" })
{{- else if eq .theme.preset "gruvbox" }}
      require("gruvbox").setup({})
{{- else if eq .theme.preset "catppuccin" }}
      require("catppuccin").setup({ background = { dark = "mocha", light = "latte" } })
{{- end }}
      vim.cmd.colorscheme("{{ $p.nvim.colorscheme }}")
      pcall(function()
        local ll = require("lualine")
        ll.setup(ll.get_config())
      end)
    end

    apply()
    vim.api.nvim_create_autocmd("FocusGained", { callback = apply })
  end,
}
